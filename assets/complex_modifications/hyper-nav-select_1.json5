{
  "title": "Caps Lock as Hyper Key (Shift + Key) 1",
  "rules": [
    {
      "description": "Hyper Navigation - Shift for Select",
      "manipulators": [

        // Shift + H = select backwards
        // I don't use this to move through tabs, I actually use ( command + shift + [ / ] )

        {
          "description": "shift + h = select left",
          "from": {
            "key_code": "h",
            "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },

        // // alternatively consider prev tab
        // {
        //   "description": "shift + h = cmd + shift + [ (prev tab)",
        //   "from": {
        //     "key_code": "h",
        //     "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
        //   },
        //   "to": [
        //     {
        //       "key_code": "[",
        //       "modifiers": ["left_command", "left_shift"]
        //     }
        //   ],
        //   "type": "basic"
        // },

        // // J
        // // I don't use this either
        // // since I use desktops, hyper application, and amethyst for window/application navigation
        // {
        //   "description": "shift + j = command + tab (next application)",
        //   "from": {
        //     "key_code": "j",
        //     "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
        //   },
        //   "to": [
        //     {
        //       "key_code": "tab",
        //       "modifiers": ["left_command"]
        //     }
        //   ],
        //   "type": "basic"
        // },
        //
        {
          "description": "shift + j = select down",
          "from": {
            "key_code": "j",
            "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "down_arrow",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },

        // // K
        // {
        //   "description": "shift + k = command + tab (prev application)",
        //   "from": {
        //     "key_code": "k",
        //     "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
        //   },
        //   "to": [
        //     {
        //       "key_code": "tab",
        //       "modifiers": ["left_command", "left_shift"]
        //     }
        //   ],
        //   "type": "basic"
        // },

        {
          "description": "shift + k = select down",
          "from": {
            "key_code": "k",
            "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "up_arrow",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },

        // L
        // {
        //   "description": "shift + l = command + tab (next tab)",
        //   "from": {
        //     "key_code": "l",
        //     "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
        //   },
        //   "to": [
        //     {
        //       "key_code": "tab",
        //       "modifiers": ["left_control"]
        //     }
        //   ],
        //   "type": "basic"
        // },

        {
          "description": "shift + l = select right",
          "from": {
            "key_code": "l",
            "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },

        // // U
        // // I won't ever remember this and would rather have it be page up (or something else that fits with Shift+UIOP)
        // {
        //   "description": "shift + u = option + command + hyphen (zoom out)",
        //   "from": {
        //     "key_code": "u",
        //     "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
        //   },
        //   "to": [
        //     {
        //       "key_code": "page_up",
        //       "modifiers": ["left_command"]
        //     }
        //   ],
        //   "type": "basic"
        // },

        {
          "description": "shift + u = select page up",
          "from": {
            "key_code": "u",
            "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "page_up",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },

        // // Shift + I
        // // What even should this be? Select home is fine but I probably will never use that
        // // I'm considering making UIOP map to bracket keys [{}], then use those for vim jumping and tab navigation
        // // which would reduce pinkie usage for [{}]
        // {
        //   "description": "shift + i = command + shift + ` (prev window within app)",
        //   "from": {
        //     "key_code": "i",
        //     "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
        //   },
        //   "to": [
        //     {
        //       "key_code": "grave_accent_and_tilde",
        //       "modifiers": ["left_command", "left_shift"]
        //     }
        //   ],
        //   "type": "basic"
        // },

        {
          "description": "shift + i = Select Home",
          "from": {
            "key_code": "i",
            "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "home",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },

        // // Shift + O
        // // Never use because I use amethyst or hyper+ctrl+j/k
        // {
        //   "description": "shift + o = command ` (next window within app)",
        //   "from": {
        //     "key_code": "o",
        //     "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
        //   },
        //   "to": [
        //     {
        //       "key_code": "grave_accent_and_tilde",
        //       "modifiers": ["left_command"]
        //     }
        //   ],
        //   "type": "basic"
        // },

        {
          "description": "shift + o = Select End",
          "from": {
            "key_code": "o",
            "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "end",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },

        // // Shift + P
        // // doesn't work, and I would forget about it anyway
        // {
        //   "description": "shift + p = option + command + equal_sign (zoom in)",
        //   "from": {
        //     "key_code": "p",
        //     "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
        //   },
        //   "to": [
        //     {
        //       "key_code": "equal_sign",
        //       "modifiers": ["left_command", "left_option"]
        //     }
        //   ],
        //   "type": "basic"
        // },

        {
          "description": "shift + p = Select page down",
          "from": {
            "key_code": "p",
            "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "page_down",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },

      ]
    }
  ]
}
