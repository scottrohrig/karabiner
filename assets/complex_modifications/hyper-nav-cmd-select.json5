{
  "title": "Caps Lock as Hyper Key (Command + Key)",
  "rules": [

    {
      "description": "Hyper Navigation - Command for Win/Tab",
      "manipulators": [

        {
          "description": "command + h = cmd + shift + [ (prev tab)",
          "from": {
            "key_code": "h",
            "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "[",
              "modifiers": ["left_command", "left_shift"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "command + j = ctrl + ` (next win)",
          "from": {
            "key_code": "j",
            "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde",
              "modifiers": ["left_command"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "command + k = ctrl + shift + ` (prev win)",
          "from": {
            "key_code": "k",
            "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde",
              "modifiers": ["left_command", "left_shift"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "command + l = cmd + shift + ] (next tab)",
          "from": {
            "key_code": "l",
            "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "]",
              "modifiers": ["left_command", "left_shift"]
            }
          ],
          "type": "basic"
        },

        {
          "description": "command + u = prev desktop",
          "from": {
            "key_code": "u",
            "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": ["left_control"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "command + i = shift + home",
          "from": {
            "key_code": "i",
            "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "home",
              "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "command + o = shift + end",
          "from": {
            "key_code": "o",
            "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "end",
 ## options
    set-window-option -g mode-keys vi
    set-option -g focus-events on  # allows terminal vim to know when it gets focus             "modifiers": ["left_shift"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "command + p = next desktop",
          "from": {
            "key_code": "p",
            "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": ["left_control"]
            }
          ],
          "type": "basic"
        }

      ]
    }
  ]
}
